# Core app
DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/nexbuy
JWT_SECRET=replace-with-a-long-random-secret
FRONTEND_ORIGINS=http://localhost:8001,http://127.0.0.1:8001
OAUTH_STATE_SECRET=replace-with-a-long-random-oauth-state-secret

# Google OAuth
GOOGLE_OAUTH_FRONTEND_REDIRECT_URL=http://localhost:8001/auth/callback
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# Apple OAuth (optional)
APPLE_OAUTH_FRONTEND_REDIRECT_URL=http://localhost:8001/auth/callback
APPLE_OAUTH_CLIENT_ID=
APPLE_OAUTH_TEAM_ID=
APPLE_OAUTH_KEY_ID=
APPLE_OAUTH_PRIVATE_KEY=
APPLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/apple/callback
APPLE_OAUTH_SCOPE=name email
APPLE_OAUTH_RESPONSE_MODE=query
OAUTH_CSRF_COOKIE_SECURE=false

# GLM
GLM_MODEL_KEY=your-glm-api-key
GLM_MODEL_NAME=glm-4.7

# OpenRouter
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_NAME=minimax/minimax-m2.5
OPENROUTER_HTTP_REFERER=http://localhost:8001
OPENROUTER_APP_TITLE=MartGennie

# Step-based model routing
LLM_ANALYSIS_PROVIDER=glm
LLM_ANALYSIS_MODEL=glm-4.7
LLM_ANALYSIS_TIMEOUT_SECONDS=90

LLM_BUNDLE_PROVIDER=openrouter
LLM_BUNDLE_MODEL=minimax/minimax-m2.5
LLM_BUNDLE_TIMEOUT_SECONDS=30

LLM_BUYER_DECISION_PROVIDER=openrouter
LLM_BUYER_DECISION_MODEL=minimax/minimax-m2.5
LLM_BUYER_DECISION_TIMEOUT_SECONDS=30

LLM_SELL_PARSER_PROVIDER=glm
LLM_SELL_PARSER_MODEL=glm-4.7
LLM_SELL_PARSER_TIMEOUT_SECONDS=30

LLM_SELL_PRICE_PROVIDER=glm
LLM_SELL_PRICE_MODEL=glm-4.7
LLM_SELL_PRICE_TIMEOUT_SECONDS=30

LLM_SELL_REPLY_PROVIDER=glm
LLM_SELL_REPLY_MODEL=glm-4.7
LLM_SELL_REPLY_TIMEOUT_SECONDS=30

LLM_EMBEDDING_PROVIDER=glm
LLM_EMBEDDING_MODEL=embedding-3
LLM_EMBEDDING_TIMEOUT_SECONDS=15
